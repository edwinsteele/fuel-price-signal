# Experiment artifacts — type-based, so new experiment dirs auto-inherit.
# Tracked by default: *.py, *.csv, *.md, *.json, *.yaml. Anything binary or
# image-like below is ignored. Add new extensions here, not per-dir entries.
experiments/**/*.png
experiments/**/*.jpg
experiments/**/*.jpeg
experiments/**/*.svg
experiments/**/*.pdf
experiments/**/*.npy
experiments/**/*.joblib
experiments/**/*.pkl
experiments/**/*.parquet
experiments/**/*.h5
experiments/**/*.html

# Scratch planning docs — kept in the tree for stable paths, not committed
PLAN_*.md


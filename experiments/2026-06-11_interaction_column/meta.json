  "definitions": {
    "A_x_shallow_elong": "network_px_std \u00d7 is_extended_shallow_descent (A inside the corner, 0 outside)",
    "A_x_other": "network_px_std \u00d7 (1 - is_extended_shallow_descent) (A outside the corner, 0 inside)",
    "A_x_smooth": "network_px_std \u00d7 elongation_ratio \u00d7 max(0, cycle_descent_slope_so_far + 0.9) (continuous corner weight; 0 for steep descent)",
    "elongation_ratio": "cycle_days_since_peak / station_baseline_cml, where station_baseline_cml = rolling median over 730d ending d-1 (closed='left'). Non-adaptive (frozen baseline).",
    "cycle_descent_slope_so_far": "(station_price_cents - cycle_last_max_cents) / cycle_days_since_peak; null at the peak.",
    "is_extended_shallow_descent": "(elongation_ratio > 1.0) AND (cycle_descent_slope_so_far > -0.9)"
  },
  "bucket_definitions": {
    "ext_descent": "elongation_ratio > 1.0",
    "ext_descent_shallow": "ext_descent AND cycle_descent_slope_so_far > -0.9"
  },
